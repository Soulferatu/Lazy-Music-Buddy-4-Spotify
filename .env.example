FLASK_APP=wacken_playlist:create_app
FLASK_ENV=development
SECRET_KEY=change-me

# Spotify Developer app credentials.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI: must match a redirect URI registered in the Spotify
# Developer dashboard EXACTLY (including scheme, host, port, path, trailing slash).
# Default dev value: http://127.0.0.1:1337/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:1337/auth/spotify/callback

# App-owned Spotify account refresh token. Captured by running the one-time
# OAuth flow at /auth/spotify/login while logged into the app-owned account.
# See wiki/stage3_playlist_creation.md for the setup walkthrough.
SPOTIFY_APP_REFRESH_TOKEN=

# Added in the setlist.fm stage.
SETLISTFM_API_KEY=
