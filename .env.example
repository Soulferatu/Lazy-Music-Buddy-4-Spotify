FLASK_APP=wacken_playlist:create_app
FLASK_ENV=development
SECRET_KEY=change-me

# Spotify Developer app credentials.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI: must match a redirect URI registered in the Spotify
# Developer dashboard. Default dev port is 1337.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:1337/callback

# App-owned Spotify account token. Added after the one-time OAuth setup.
SPOTIFY_APP_REFRESH_TOKEN=

# Added in the setlist.fm stage.
SETLISTFM_API_KEY=
